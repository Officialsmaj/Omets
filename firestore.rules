rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, verified, verificationCode, firstName, lastName, country, dateOfBirth
    //
    // Collection: courses
    // Fields: title, description, instructor, duration, price, image, category, difficulty
    //
    // Collection: workshops
    // Fields: title, date, instructor, description, image
    //
    // Collection: consultations
    // Fields: category, expertId, date, time, problem, userId, status
    //
    // Collection: forumPosts
    // Fields: title, content, authorId, authorName, createdAt, likes, commentsCount
    //
    // Collection: enrollments
    // Fields: userId, courseId, enrolledAt, progress
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "officialsmaj@gmail.com" && request.auth.token.email_verified == true));
    }

    function isExpert() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'expert';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin', 'expert'] &&
             (!('verified' in data) || data.verified is bool) &&
             (!('verificationCode' in data) || (data.verificationCode is string && data.verificationCode.size() == 6));
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['title', 'description', 'instructor', 'price']) &&
             data.title is string && data.title.size() < 100 &&
             data.description is string && data.description.size() < 2000 &&
             data.price is number && data.price >= 0;
    }

    function isValidWorkshop(data) {
      return data.keys().hasAll(['title', 'date', 'instructor']) &&
             data.title is string && data.title.size() < 100 &&
             data.date is string;
    }

    function isValidConsultation(data) {
      return data.keys().hasAll(['category', 'expertId', 'date', 'time', 'userId', 'status']) &&
             data.userId == request.auth.uid;
    }

    function isValidForumPost(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'authorName', 'createdAt']) &&
             data.authorId == request.auth.uid &&
             data.title is string && data.title.size() < 200 &&
             data.content is string && data.content.size() < 5000;
    }

    function isValidEnrollment(data) {
      return data.keys().hasAll(['userId', 'courseId', 'enrolledAt']) &&
             data.userId == request.auth.uid &&
             data.courseId is string &&
             data.enrolledAt is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /courses/{courseId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /workshops/{workshopId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /consultations/{consultationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.expertId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidConsultation(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.expertId == request.auth.uid || isAdmin());
    }

    match /forumPosts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidForumPost(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidEnrollment(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
